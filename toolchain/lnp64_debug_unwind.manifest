# LNP64 debug/unwind manifest v0.
# Backend-facing minimums for the initial LLVM target.
debug_format=DWARFv5
line_tables=required
real_llvm_debug_sections=clang_debug_sections_object
line_table_decode=blocked_until_debug_relocation_decoding
register_numbers=r0-r31,TP
dwarf_register_map=r0-r31:0-31,TP:33
stack_pointer=r31
cfa_register=r31
return_address=r1
cfi=required_for_non_leaf
frame_pointer=optional
eh_frame=not_required_v0
exception_model=none_v0
signal_unwind=psabi_signal_frame
