# LNP64 Clang/lld driver contract v0.
triple=lnp64-unknown-none
cflags=-ffreestanding,-fno-pic,-fno-jump-tables,-isystem,target/lnp64-sysroot/usr/include,-Itoolchain
assembler=llvm-mc
assembler_flags=-triple=lnp64-unknown-none,-filetype=obj
linker=ld.lld
linker_flags=-static,-m,elf64lnp64,-T,target/lnp64-sysroot/usr/lib/lnp64/lnp64_static.ld
crt0=target/lnp64-sysroot/usr/lib/lnp64/crt0.o
intrinsic_header=target/lnp64-sysroot/usr/include/lnp64/intrinsics.h
loader_probe=lnp64 elf-plan
status=active_real_backend
