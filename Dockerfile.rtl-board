FROM debian:bookworm

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        fpga-icestorm \
        fpga-icestorm-chipdb \
        nextpnr-ice40 \
        python3 \
        python3-serial \
        usbutils \
        verilator \
        yosys \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work
COPY . .

CMD ["bash", "scripts/run_rtl_board_ice40_s0.sh"]
